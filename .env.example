# Copia este archivo a .env y completá los valores.
# .env está en .gitignore — nunca se commitea.

# 21st.dev Magic MCP — generá la tuya en https://21st.dev/magic
TWENTY_FIRST_API_KEY=

# Supabase — pedile las credenciales al admin del proyecto
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — para crear miembros/admin server-side.
# NUNCA expongas esta key al cliente. Solo se usa en server actions / route handlers.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — pedila al admin o generala en https://console.anthropic.com
ANTHROPIC_API_KEY=

# Dropbox — import de cotizaciones. App en https://www.dropbox.com/developers/apps
# El refresh token se genera una vez con el flujo OAuth (offline access).
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# QuickBooks (vía gateway MCP de Dicec) — sync de clientes y, luego, budget/gastado.
# La URL ES el secreto (el path largo = API key con CRUD sobre la contabilidad).
# Tratá como secreto: solo server-side, nunca en código cliente ni en el repo.
QBO_MCP_URL=

# Demo mode — ON por default: auto-loguea como demo@cotiza.local y saltea /login.
# Para volver al login normal: DEMO_MODE=false.
# DEMO_MODE=false
